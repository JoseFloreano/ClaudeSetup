# ══════════════════════════════════════════════════════════════
#  Graphiti + FalkorDB — Variables de entorno
#
#  UBICACIÓN DE ESTE ARCHIVO (auditoría A4 — contiene API keys):
#    Windows:      %LOCALAPPDATA%\graphiti\.env
#    macOS/Linux:  ~/.local/share/graphiti/.env
#  NUNCA en OneDrive, NUNCA en git. setup-new-machine lo genera ahí
#  y lo usa con: docker compose --env-file <esa ruta> up -d
# ══════════════════════════════════════════════════════════════

# ── RUTAS DE DATOS — ESTRATEGIA A: SIEMPRE DISCO LOCAL (H2, auditoría A1) ──
#
# Los datos vivos de FalkorDB van en disco local. A OneDrive solo van
# los snapshots que genera backup-graph.ps1/.sh (cada 4 horas).
# El compose falla explícitamente si estas variables no están definidas.
#
# Windows (formato Docker Desktop — el setup lo genera automáticamente):
# FALKORDB_DATA_PATH=/c/Users/TU_USUARIO/AppData/Local/graphiti/data
# CONFIG_PATH=/c/Users/TU_USUARIO/AppData/Local/graphiti/config
#
# macOS / Linux:
# FALKORDB_DATA_PATH=/Users/TU_USUARIO/.local/share/graphiti/data
# CONFIG_PATH=/Users/TU_USUARIO/.local/share/graphiti/config
#
FALKORDB_DATA_PATH=
CONFIG_PATH=

# ⛔ Si el valor contiene "OneDrive", estás en la configuración que la
#    investigación prohibió (corrupción silenciosa del grafo).
#    Estrategia B/C: ver setup/README.md — requieren protocolo consciente.

# ── VERSIONES PINNEADAS (auditoría A5 — obligatorias, el compose falla sin ellas)
#
# El día del setup: docker pull falkordb/falkordb:latest y anota el tag
# estable actual. Actualiza el pin a propósito y en TODAS las laptops a la vez.
FALKORDB_VERSION=
GRAPHITI_MCP_VERSION=

# ── BACKUPS (solo recibe snapshots terminados)
# Multi-laptop:  C:\Users\TU_USUARIO\OneDrive\DevSetup\graphiti-data\backups
# Single-laptop (sin OneDrive): C:\Users\TU_USUARIO\DevSetup\graphiti-data\backups
#   ⚠ En modo local los backups quedan en el mismo disco: agenda copia
#     periódica a disco externo/nube (ver "Modo single-laptop" en el README).
BACKUP_DIR=

# ── LLM PROVIDER ─────────────────────────────────────────────────────────
#
# Graphiti llama al LLM SOLO en escritura (extracción de entidades).
# La key del provider elegido es obligatoria (setup-new-machine lo valida).
# NO usar anthropic con modelos chicos (H7: structured output experimental
# → fallos de extracción silenciosos).
#
# ══ RUTA 1 — OPENAI (pago, óptima) ══
# Mejor structured output; costo ~$0.50–1.50/mes con uso intensivo (doc 07).
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# MODEL_NAME=gpt-4.1-mini
# SMALL_MODEL_NAME=gpt-4.1-nano
#
# ══ RUTA 2 — GEMINI (GRATIS — recomendada si no quieres pagar API) ══
# Free tier sin tarjeta: ~15 RPM / 1,500 req/día / ~1M tokens-por-minuto
# en flash (julio 2026 — verificar en ai.google.dev/gemini-api/docs/rate-limits).
# Para ~10 episodios/sesión sobra de largo. Structured output nativo estable.
# Key gratis en: aistudio.google.com
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...
# MODEL_NAME=gemini-2.0-flash
# SMALL_MODEL_NAME=gemini-2.0-flash-lite
# ⚠ Embedder: en ruta gratis usa también gemini o sentence_transformers
#   (local) en config.yaml — el embedder default es openai y pediría su key.
#
# ══ RUTA 3 — GROQ (gratis, rapidísimo — pero ojo con el TPM) ══
# Free tier: ~30 RPM y ~14,400 req/día PERO solo ~6,000 tokens-POR-MINUTO.
# El cuello para Graphiti es el TPM: cada episodio son 1,500–3,000 tokens
# × 1–3 llamadas → una ráfaga de fin de sesión puede dar 429s.
# Si lo usas: SEMAPHORE_LIMIT=2 y modelo 70b (el 8b falla más JSON schema → R3).
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# MODEL_NAME=llama-3.3-70b-versatile
# SMALL_MODEL_NAME=llama-3.3-70b-versatile   # NO usar 8b-instant para extracción
#
# ── Configuración activa (descomenta/edita UNA ruta de arriba) ──
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MODEL_NAME=gpt-4.1-mini
SMALL_MODEL_NAME=gpt-4.1-nano

# ── FALKORDB ──────────────────────────────────────────────────────────────
# Los puertos están ligados a 127.0.0.1 en el compose (no salen de la
# máquina), por eso el password vacío es tolerable en laptop personal.
FALKORDB_PASSWORD=

# ── CONCURRENCIA (protección contra rate limits) ─────────────────────────
# openai Tier 1: 2 | Tier 2: 8 | Tier 3+: 15  (reducir si ves errores 429)
SEMAPHORE_LIMIT=3
